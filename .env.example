# ── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://bryoehuhhhjqcueomgev.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here

# ── Sentry error tracking (Phase 4) ──────────────────────────────────────────
# Obtain DSN from: https://sentry.io → Settings → Projects → icareeros → Client Keys
# Leave blank to disable Sentry (safe for local dev)
VITE_SENTRY_DSN=

# Release version — injected by CI; set manually for local testing if desired
VITE_APP_VERSION=0.0.0

# ── Sentry source-map upload (CI/CD only — never commit these) ───────────────
# Set in Vercel environment or GitHub Actions secrets
SENTRY_AUTH_TOKEN=
SENTRY_ORG=jabri-solutions
SENTRY_PROJECT=icareeros

# ── BetterStack monitoring ────────────────────────────────────────────────────
# Set these as Supabase Edge Function secrets (supabase secrets set ...)
# NEVER commit real values here.
#
# Logtail source token — forwards all edge function logs to BetterStack Logs.
# Obtain from: https://logs.betterstack.com → Sources → New Source → Supabase
BETTERSTACK_SOURCE_TOKEN=

# Heartbeat URL — pinged after each successful job-feeds cron run.
# Obtain from: https://uptime.betterstack.com → Monitors → New Monitor → Heartbeat
BETTERSTACK_HEARTBEAT_URL=
