VITE_SENTRY_DSN=

# Release version — injected by CI; set manually for local testing if desired
VITE_APP_VERSION=0.0.0

# ── Sentry source-map upload (CI/CD only — never commit these) ───────────────
# Set in Vercel environment or GitHub Actions secrets
SENTRY_AUTH_TOKEN=
SENTRY_ORG=jabri-solutions
SENTRY_PROJECT=icareeros
